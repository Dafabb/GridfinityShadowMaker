Step 2 DXF to STL.json
sections.json
/test

# Ignore the created copy of the /src folder in working folder
tool_holders/src

# Ignore generated contour DXF files across the repo
# Pattern: *_contour_N.dxf where * is any prefix and N is any number
# Examples: cl_420_contour_1.dxf, mw_12314_contour_12.dxf, xyz_7_contour_999.dxf
# Works in any directory or subdirectory
**/*_contour_[0-9]*.dxf

# If you want to be more specific and only match prefixes that look like 
# letters_underscore_numbers before _contour, use this instead:
# **[a-z]*_[0-9]*_contour_[0-9]*.dxf

# If you only want to match your two known prefixes cl_ and mw_ for now:
# **/cl_*_contour_[0-9]*.dxf
# **/mw_*_contour_[0-9]*.dxf

# Ignore generated contour DXF files across the repo
**/*_contour_[0-9]*.dxf

# Ignore work files: png, jpg, jpeg, 3mf, scad
# Only in tool_holders/ and tool_holders/pending/ and their subfolders
# Use forward slashes even on Windows
tool_holders/*.png
tool_holders/*.jpg
tool_holders/*.jpeg
tool_holders/*.3mf
tool_holders/*.scad
tool_holders/*.json

tool_holders/pending/**/*.png
tool_holders/pending/**/*.jpg
tool_holders/pending/**/*.jpeg
tool_holders/pending/**/*.3mf
tool_holders/pending/**/*.scad
tool_holders/pending/**/*.json

# Exception: keep everything in tool_holders/final/
# The ! must come AFTER the ignore rules above
!tool_holders/final/
